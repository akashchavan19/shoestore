# ============================================================
#  Onistuka — Environment Variables
#  
#  LOCAL DEV:  Copy this to .env and fill in values
#  PRODUCTION: Set these as environment variables in your
#              hosting dashboard (Railway/Render/etc)
#
#  NEVER commit .env to git — it contains secrets
# ============================================================

# ── Django Core ──────────────────────────────────────────────
# Generate a real key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-very-long-random-secret-key-minimum-50-chars

# False in production always
DEBUG=False

# Your actual domain in production
# e.g. ALLOWED_HOSTS=onistuka.com,www.onistuka.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Database ─────────────────────────────────────────────────
# PostgreSQL URL — Railway/Render provide this automatically
# Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgres://user:password@localhost:5432/onistuka_db

# ── Redis ────────────────────────────────────────────────────
# Redis URL — Railway/Render provide this automatically
# Format: redis://HOST:PORT/DB_NUMBER
REDIS_URL=redis://127.0.0.1:6379/1

# ── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://onistuka.com,https://www.onistuka.com

# ── Email (use SendGrid for production) ──────────────────────
EMAIL_HOST=smtp.sendgrid.net
EMAIL_PORT=587
EMAIL_HOST_USER=apikey
EMAIL_HOST_PASSWORD=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@onistuka.com

# ── Razorpay ─────────────────────────────────────────────────
# Use LIVE keys in production (not test keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_live_razorpay_secret
# Set this in Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
